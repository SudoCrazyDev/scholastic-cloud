# LiveKit server credentials (from https://cloud.livekit.io -> Settings -> Keys,
# or your self-hosted server config)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# STT/LLM/TTS run on LiveKit Inference (billed through your LiveKit Cloud
# account) — no separate provider API keys are needed.
