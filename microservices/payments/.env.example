APP_NAME="Schoolmate Payments"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=payments
DB_USERNAME=payments_user
DB_PASSWORD=payments_password

# Internal token required for main API -> payments service calls
PAYMENTS_INTERNAL_TOKEN=

# Main API callback (payments service -> main API)
PAYMENTS_CALLBACK_URL=
PAYMENTS_CALLBACK_TOKEN=
PAYMENTS_CALLBACK_TIMEOUT=10

# Maya Checkout configuration
MAYA_BASE_URL=https://pg-sandbox.paymaya.com
MAYA_PUBLIC_KEY=
MAYA_SECRET_KEY=
MAYA_WEBHOOK_SIGNATURE_KEY=
MAYA_TIMEOUT=20
