---
import MotionSection from './react/MotionSection';
// Product UI preview: HTML/CSS mockups (no raster screenshots required).
---

<MotionSection
	client:visible
	id="product-ui"
	className="scroll-mt-24 border-t border-zinc-200/80 bg-gradient-to-b from-white via-stone-50/80 to-white py-24 px-4 sm:px-6 lg:px-8"
	aria-labelledby="product-ui-heading"
>
	<div class="mx-auto max-w-7xl">
		<div class="mb-16 max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-violet-600">Interface</p>
			<h2 id="product-ui-heading" class="mt-3 font-display text-4xl tracking-tight text-zinc-900 sm:text-5xl text-balance">
				What you actually click inside Scholastic Cloud
			</h2>
			<p class="mt-4 text-lg text-zinc-600">
				Faithful-feeling UI chrome—tables, tabs, and panels—so stakeholders can picture day-to-day work, not just a bullet list.
			</p>
		</div>

		<!-- Finance -->
		<div class="mb-20 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
			<div class="order-2 lg:order-1">
				<p class="text-xs font-semibold uppercase tracking-wider text-violet-600">Finance</p>
				<h3 class="mt-2 font-display text-2xl text-zinc-900 sm:text-3xl">Cashiering & collections</h3>
				<p class="mt-3 text-zinc-600 leading-relaxed">
					Receipt-focused workflows with line items, payment mode, and student context—mirroring how registrars and cashiers actually post fees.
				</p>
				<ul class="mt-6 space-y-2 text-sm text-zinc-600">
					<li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-violet-500"></span>OR series, discounts, and running balances visible in one view</li>
					<li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-violet-500"></span>Student ledger drill-down without leaving the module</li>
				</ul>
			</div>
			<div class="order-1 lg:order-2">
				<div class="mock-browser">
					<div class="mock-browser-chrome">
						<span class="mock-dot bg-red-400"></span>
						<span class="mock-dot bg-amber-400"></span>
						<span class="mock-dot bg-emerald-400"></span>
						<span class="mock-url">scholasticcloud.app / finance / cashiering</span>
					</div>
					<div class="mock-browser-body">
						<div class="mb-3 flex flex-wrap items-center justify-between gap-2 border-b border-zinc-100 pb-3">
							<div>
								<p class="text-[10px] font-medium uppercase tracking-wider text-zinc-400">Cashier session</p>
								<p class="text-sm font-semibold text-zinc-900">Gate A · Main campus</p>
							</div>
							<div class="flex gap-2">
								<span class="rounded-md bg-zinc-100 px-2 py-1 text-[10px] font-medium text-zinc-600">Today</span>
								<span class="rounded-md bg-emerald-50 px-2 py-1 text-[10px] font-semibold text-emerald-700">Synced</span>
							</div>
						</div>
						<div class="grid gap-3 sm:grid-cols-[1fr_7rem]">
							<div class="overflow-hidden rounded-lg border border-zinc-200">
								<table class="w-full text-left text-[10px]">
									<thead class="bg-zinc-50 text-[9px] font-semibold uppercase tracking-wide text-zinc-500">
										<tr>
											<th class="px-2 py-1.5">OR #</th>
											<th class="px-2 py-1.5">Student</th>
											<th class="px-2 py-1.5 text-right">Amount</th>
											<th class="px-2 py-1.5">Status</th>
										</tr>
									</thead>
									<tbody class="divide-y divide-zinc-100 bg-white text-zinc-700">
										<tr>
											<td class="px-2 py-1.5 font-mono text-violet-700">2025-0142</td>
											<td class="px-2 py-1.5">Reyes, Ana M.</td>
											<td class="px-2 py-1.5 text-right tabular-nums">₱4,250.00</td>
											<td class="px-2 py-1.5"><span class="rounded bg-emerald-50 px-1.5 py-0.5 text-[9px] font-medium text-emerald-700">Paid</span></td>
										</tr>
										<tr>
											<td class="px-2 py-1.5 font-mono text-violet-700">2025-0143</td>
											<td class="px-2 py-1.5">Santos, Jiro K.</td>
											<td class="px-2 py-1.5 text-right tabular-nums">₱2,100.00</td>
											<td class="px-2 py-1.5"><span class="rounded bg-amber-50 px-1.5 py-0.5 text-[9px] font-medium text-amber-800">Partial</span></td>
										</tr>
										<tr>
											<td class="px-2 py-1.5 font-mono text-zinc-400">—</td>
											<td class="px-2 py-1.5 text-zinc-400">Walk-in inquiry</td>
											<td class="px-2 py-1.5 text-right tabular-nums text-zinc-400">—</td>
											<td class="px-2 py-1.5"><span class="rounded bg-zinc-100 px-1.5 py-0.5 text-[9px] text-zinc-500">Queued</span></td>
										</tr>
									</tbody>
								</table>
							</div>
							<div class="flex flex-col gap-2 rounded-lg border border-violet-100 bg-gradient-to-b from-violet-50/90 to-white p-3">
								<p class="text-[9px] font-medium uppercase tracking-wider text-violet-600">Shift total</p>
								<p class="font-display text-xl tabular-nums text-zinc-900">₱48,920</p>
								<div class="mt-auto space-y-1 border-t border-violet-100 pt-2 text-[9px] text-zinc-500">
									<div class="flex justify-between"><span>Cash</span><span class="tabular-nums text-zinc-700">₱32,400</span></div>
									<div class="flex justify-between"><span>Transfer</span><span class="tabular-nums text-zinc-700">₱16,520</span></div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Grades -->
		<div class="mb-20 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
			<div class="mock-browser lg:order-1">
				<div class="mock-browser-chrome">
					<span class="mock-dot bg-red-400"></span>
					<span class="mock-dot bg-amber-400"></span>
					<span class="mock-dot bg-emerald-400"></span>
					<span class="mock-url">scholasticcloud.app / consolidated-grades</span>
				</div>
				<div class="mock-browser-body">
					<div class="mb-3 flex flex-wrap items-end justify-between gap-2">
						<div>
							<p class="text-[10px] font-medium uppercase tracking-wider text-zinc-400">Grade 10 · Hope</p>
							<p class="text-sm font-semibold text-zinc-900">SF9 · Quarter 3</p>
						</div>
						<div class="flex rounded-lg bg-zinc-100 p-0.5 text-[10px] font-medium">
							<span class="rounded-md bg-white px-2 py-1 text-zinc-900 shadow-sm">Q3</span>
							<span class="px-2 py-1 text-zinc-500">Q4</span>
						</div>
					</div>
					<div class="overflow-hidden rounded-lg border border-zinc-200">
						<table class="w-full text-left text-[10px]">
							<thead class="bg-zinc-50 text-[9px] font-semibold uppercase tracking-wide text-zinc-500">
								<tr>
									<th class="px-2 py-1.5">Learner</th>
									<th class="px-2 py-1.5 text-center">Written</th>
									<th class="px-2 py-1.5 text-center">Perf.</th>
									<th class="px-2 py-1.5 text-center">Final</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-zinc-100 bg-white">
								<tr>
									<td class="px-2 py-1.5 font-medium text-zinc-800">Castro, L.</td>
									<td class="px-2 py-1.5 text-center tabular-nums">88</td>
									<td class="px-2 py-1.5 text-center tabular-nums">90</td>
									<td class="px-2 py-1.5 text-center"><span class="rounded bg-violet-100 px-1.5 py-0.5 text-[9px] font-semibold text-violet-800">89</span></td>
								</tr>
								<tr>
									<td class="px-2 py-1.5 font-medium text-zinc-800">Dela Cruz, M.</td>
									<td class="px-2 py-1.5 text-center tabular-nums">92</td>
									<td class="px-2 py-1.5 text-center tabular-nums">91</td>
									<td class="px-2 py-1.5 text-center"><span class="rounded bg-violet-100 px-1.5 py-0.5 text-[9px] font-semibold text-violet-800">92</span></td>
								</tr>
								<tr>
									<td class="px-2 py-1.5 font-medium text-zinc-800">Navarro, P.</td>
									<td class="px-2 py-1.5 text-center tabular-nums">85</td>
									<td class="px-2 py-1.5 text-center tabular-nums">87</td>
									<td class="px-2 py-1.5 text-center"><span class="rounded bg-violet-100 px-1.5 py-0.5 text-[9px] font-semibold text-violet-800">86</span></td>
								</tr>
							</tbody>
						</table>
					</div>
					<div class="mt-3 flex gap-2">
						<span class="rounded-md border border-zinc-200 bg-white px-2 py-1 text-[9px] font-medium text-zinc-600">Export PDF</span>
						<span class="rounded-md border border-violet-200 bg-violet-50 px-2 py-1 text-[9px] font-semibold text-violet-800">Submit to registrar</span>
					</div>
				</div>
			</div>
			<div class="lg:order-2">
				<p class="text-xs font-semibold uppercase tracking-wider text-fuchsia-600">Grades</p>
				<h3 class="mt-2 font-display text-2xl text-zinc-900 sm:text-3xl">Consolidation & SF9</h3>
				<p class="mt-3 text-zinc-600 leading-relaxed">
					Section-level rollups with quarter tabs and export actions—what teachers and registrars see when closing a grading period.
				</p>
				<ul class="mt-6 space-y-2 text-sm text-zinc-600">
					<li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-fuchsia-500"></span>Written vs performance columns preserved for transparency</li>
					<li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-fuchsia-500"></span>Registrar handoff without retyping finals</li>
				</ul>
			</div>
		</div>

		<!-- Attendance -->
		<div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-emerald-600">Attendance</p>
				<h3 class="mt-2 font-display text-2xl text-zinc-900 sm:text-3xl">Teacher grid & daily session</h3>
				<p class="mt-3 text-zinc-600 leading-relaxed">
					A compact grid that reads at a glance: who was present, late, or excused—similar to realtime class monitoring views.
				</p>
			</div>
			<div>
				<div class="mock-browser">
					<div class="mock-browser-chrome">
						<span class="mock-dot bg-red-400"></span>
						<span class="mock-dot bg-amber-400"></span>
						<span class="mock-dot bg-emerald-400"></span>
						<span class="mock-url">scholasticcloud.app / teacher-attendance</span>
					</div>
					<div class="mock-browser-body">
						<div class="mb-3 flex items-center justify-between border-b border-zinc-100 pb-3">
							<div>
								<p class="text-[10px] font-medium uppercase tracking-wider text-zinc-400">Advisory · 10-Hope</p>
								<p class="text-sm font-semibold text-zinc-900">July 14 · Session 2</p>
							</div>
							<span class="flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-1 text-[9px] font-semibold text-emerald-700">
								<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-500"></span>
								Live
							</span>
						</div>
						<div class="grid grid-cols-[1fr_2.5rem_2.5rem_2.5rem] gap-1 text-[9px] font-semibold uppercase tracking-wide text-zinc-500">
							<span class="px-1">Student</span>
							<span class="text-center">P</span>
							<span class="text-center">L</span>
							<span class="text-center">E</span>
						</div>
						<div class="mt-1 space-y-1">
							<div class="grid grid-cols-[1fr_2.5rem_2.5rem_2.5rem] items-center gap-1 rounded-md bg-zinc-50 py-1.5 pl-1 pr-0 text-[10px]">
								<span class="truncate font-medium text-zinc-800">Alonzo, S.</span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-emerald-500/90"></span></span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-zinc-200"></span></span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-zinc-200"></span></span>
							</div>
							<div class="grid grid-cols-[1fr_2.5rem_2.5rem_2.5rem] items-center gap-1 rounded-md py-1.5 pl-1 pr-0 text-[10px]">
								<span class="truncate font-medium text-zinc-800">Bautista, R.</span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-emerald-500/90"></span></span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-amber-400"></span></span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-zinc-200"></span></span>
							</div>
							<div class="grid grid-cols-[1fr_2.5rem_2.5rem_2.5rem] items-center gap-1 rounded-md bg-zinc-50 py-1.5 pl-1 pr-0 text-[10px]">
								<span class="truncate font-medium text-zinc-800">Cortez, T.</span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-zinc-200"></span></span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-zinc-200"></span></span>
								<span class="flex justify-center"><span class="h-4 w-4 rounded bg-sky-500/90"></span></span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</MotionSection>
