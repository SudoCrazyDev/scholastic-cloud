---
import '../styles/global.css';
import ProductUiSection from '../components/ProductUiSection.astro';
import LenisSmooth from '../components/react/LenisSmooth';
import HeroThreeCanvas from '../components/react/HeroThreeCanvas';
import HeroMotion from '../components/react/HeroMotion';
import MotionSection from '../components/react/MotionSection';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Scholastic Cloud — grades, finance, attendance, certificates, and school operations in one cloud platform built for modern institutions." />
		<title>Scholastic Cloud — School operations, elevated</title>
		<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1770945751834620" crossorigin="anonymous"></script>
	</head>
	<body class="bg-stone-50">
		<LenisSmooth client:load />
		<!-- Navigation -->
		<nav class="fixed top-0 w-full z-50 border-b border-white/10 bg-zinc-950/75 backdrop-blur-xl transition-colors duration-300" id="navbar">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between items-center h-16 md:h-[4.25rem]">
					<a href="#" class="flex items-center gap-3 group">
						<div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-violet-500 to-fuchsia-600 shadow-lg shadow-violet-500/25 transition-transform group-hover:scale-[1.02]">
							<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
							</svg>
						</div>
						<span class="font-display text-xl tracking-tight text-white">Scholastic Cloud</span>
					</a>
					<div class="hidden md:flex items-center gap-10 text-sm font-medium">
						<a href="#showcase" class="text-zinc-300 hover:text-white transition-colors">Capabilities</a>
						<a href="#product-ui" class="text-zinc-300 hover:text-white transition-colors">Preview</a>
						<a href="#features" class="text-zinc-300 hover:text-white transition-colors">Features</a>
						<a href="#solution" class="text-zinc-300 hover:text-white transition-colors">Timeline</a>
						<a href="#benefits" class="text-zinc-300 hover:text-white transition-colors">Why us</a>
						<a href="#cta" class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-zinc-900 shadow-lg shadow-black/20 transition hover:bg-zinc-100">Get started</a>
					</div>
					<button type="button" id="nav-toggle" class="md:hidden inline-flex items-center justify-center rounded-lg p-2 text-zinc-300 hover:bg-white/10 hover:text-white" aria-expanded="false" aria-controls="mobile-menu">
						<span class="sr-only">Open menu</span>
						<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="nav-icon-open">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
						</svg>
						<svg class="hidden h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="nav-icon-close">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				<div id="mobile-menu" class="hidden md:hidden border-t border-white/10 py-4">
					<div class="flex flex-col gap-1 text-sm font-medium">
						<a href="#showcase" class="rounded-lg px-3 py-2 text-zinc-200 hover:bg-white/5">Capabilities</a>
						<a href="#product-ui" class="rounded-lg px-3 py-2 text-zinc-200 hover:bg-white/5">Preview</a>
						<a href="#features" class="rounded-lg px-3 py-2 text-zinc-200 hover:bg-white/5">Features</a>
						<a href="#solution" class="rounded-lg px-3 py-2 text-zinc-200 hover:bg-white/5">Timeline</a>
						<a href="#benefits" class="rounded-lg px-3 py-2 text-zinc-200 hover:bg-white/5">Why us</a>
						<a href="#cta" class="mt-2 rounded-full bg-white px-4 py-3 text-center font-semibold text-zinc-900">Get started</a>
					</div>
				</div>
			</div>
		</nav>

		<!-- Hero -->
		<section class="relative min-h-[100svh] flex items-center overflow-hidden pt-20 pb-24 px-4 sm:px-6 lg:px-8 mesh-hero">
			<HeroThreeCanvas client:load />
			<div class="noise-overlay" aria-hidden="true"></div>
			<div class="pointer-events-none absolute -left-32 top-1/4 h-96 w-96 rounded-full bg-violet-600/20 blur-3xl"></div>
			<div class="pointer-events-none absolute -right-24 bottom-0 h-[28rem] w-[28rem] rounded-full bg-fuchsia-600/15 blur-3xl"></div>

			<HeroMotion client:load>
				<div class="lg:col-span-6">
					<p class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-violet-200/90">
						Education operations suite
					</p>
					<h1 class="font-display text-4xl leading-[1.08] text-white sm:text-5xl lg:text-6xl xl:text-[3.5rem] text-balance">
						School operations,
						<span class="bg-gradient-to-r from-violet-200 via-fuchsia-200 to-white bg-clip-text text-transparent"> elevated.</span>
					</h1>
					<p class="mt-6 max-w-xl text-lg leading-relaxed text-zinc-400">
						One cloud workspace for grades, finance, attendance, certificates, and everyday administration—built for principals, registrars, teachers, and students.
					</p>
					<div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
						<a href="#cta" class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3.5 text-base font-semibold text-zinc-900 shadow-xl shadow-black/30 transition hover:bg-zinc-100">
							Start a trial
						</a>
						<a href="#showcase" class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/5 px-8 py-3.5 text-base font-semibold text-white backdrop-blur transition hover:bg-white/10">
							Explore capabilities
						</a>
					</div>
					<dl class="mt-14 grid grid-cols-3 gap-6 border-t border-white/10 pt-10 sm:max-w-md">
						<div>
							<dt class="text-xs font-medium uppercase tracking-wider text-zinc-500">Coverage</dt>
							<dd class="mt-1 font-display text-2xl text-white">All-in-one</dd>
						</div>
						<div>
							<dt class="text-xs font-medium uppercase tracking-wider text-zinc-500">Access</dt>
							<dd class="mt-1 font-display text-2xl text-white">Role-based</dd>
						</div>
						<div>
							<dt class="text-xs font-medium uppercase tracking-wider text-zinc-500">Deploy</dt>
							<dd class="mt-1 font-display text-2xl text-white">Cloud</dd>
						</div>
					</dl>
				</div>

				<div class="lg:col-span-6">
					<div class="relative mx-auto max-w-lg lg:max-w-none">
						<div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-tr from-violet-500/20 via-transparent to-fuchsia-500/20 blur-2xl"></div>
						<div class="relative overflow-hidden rounded-2xl border border-white/10 bg-zinc-900/80 shadow-2xl shadow-black/50 ring-1 ring-white/10 backdrop-blur-xl">
							<div class="flex items-center gap-2 border-b border-white/10 bg-zinc-950/80 px-4 py-3">
								<span class="h-2.5 w-2.5 rounded-full bg-red-400/90"></span>
								<span class="h-2.5 w-2.5 rounded-full bg-amber-400/90"></span>
								<span class="h-2.5 w-2.5 rounded-full bg-emerald-400/90"></span>
								<span class="ml-3 flex-1 truncate rounded-md bg-zinc-800/80 px-3 py-1 text-[11px] text-zinc-500">app.scholasticcloud — Dashboard</span>
							</div>
							<div class="grid gap-0 sm:grid-cols-[7.5rem_1fr]">
								<div class="hidden border-r border-white/5 bg-zinc-950/50 p-3 sm:block">
									<div class="space-y-2">
										<div class="h-2 w-full rounded bg-violet-500/40"></div>
										<div class="h-2 w-4/5 rounded bg-zinc-700/80"></div>
										<div class="h-2 w-3/5 rounded bg-zinc-800/80"></div>
										<div class="mt-6 h-2 w-full rounded bg-zinc-800/60"></div>
										<div class="h-2 w-full rounded bg-zinc-800/60"></div>
										<div class="h-2 w-2/3 rounded bg-zinc-800/60"></div>
									</div>
								</div>
								<div class="p-5 sm:p-6">
									<div class="mb-5 flex flex-wrap items-end justify-between gap-3">
										<div>
											<p class="text-xs font-medium uppercase tracking-wider text-zinc-500">Today</p>
											<p class="font-display text-2xl text-white">Academic overview</p>
										</div>
										<span class="rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-300">Live sync</span>
									</div>
									<div class="grid gap-3 sm:grid-cols-2">
										<div class="rounded-xl border border-white/10 bg-gradient-to-br from-violet-500/15 to-transparent p-4">
											<p class="text-xs text-zinc-400">Consolidated grades</p>
											<p class="mt-2 font-display text-3xl text-white">SF9 · Q3</p>
											<div class="mt-3 h-1.5 overflow-hidden rounded-full bg-zinc-800">
												<div class="h-full w-[72%] rounded-full bg-gradient-to-r from-violet-400 to-fuchsia-400"></div>
											</div>
										</div>
										<div class="rounded-xl border border-white/10 bg-zinc-950/60 p-4">
											<p class="text-xs text-zinc-400">Collections</p>
											<p class="mt-2 font-display text-3xl text-white">₱ · Cashier</p>
											<p class="mt-2 text-xs text-zinc-500">Receipts & ledger in one flow</p>
										</div>
									</div>
									<div class="mt-4 grid grid-cols-3 gap-2">
										<div class="rounded-lg border border-white/5 bg-zinc-900/80 p-3 text-center">
											<p class="text-[10px] uppercase tracking-wider text-zinc-500">Gate</p>
											<p class="mt-1 text-sm font-semibold text-white">In / Out</p>
										</div>
										<div class="rounded-lg border border-white/5 bg-zinc-900/80 p-3 text-center">
											<p class="text-[10px] uppercase tracking-wider text-zinc-500">Certs</p>
											<p class="mt-1 text-sm font-semibold text-white">Builder</p>
										</div>
										<div class="rounded-lg border border-white/5 bg-zinc-900/80 p-3 text-center">
											<p class="text-[10px] uppercase tracking-wider text-zinc-500">Forms</p>
											<p class="mt-1 text-sm font-semibold text-white">Custom</p>
										</div>
									</div>
									<div class="mt-4 overflow-hidden rounded-lg border border-white/10">
										<div class="flex items-center justify-between border-b border-white/10 bg-zinc-950/50 px-3 py-2">
											<span class="text-[10px] font-medium uppercase tracking-wider text-zinc-500">Recent activity</span>
											<span class="text-[10px] text-violet-300">Live</span>
										</div>
										<table class="w-full text-left text-[10px] text-zinc-300">
											<tbody class="divide-y divide-white/5">
												<tr class="bg-zinc-900/40">
													<td class="px-3 py-2">Enrollment sync</td>
													<td class="px-3 py-2 text-right tabular-nums text-emerald-300/90">OK</td>
												</tr>
												<tr>
													<td class="px-3 py-2">Grade upload · Q3</td>
													<td class="px-3 py-2 text-right tabular-nums text-zinc-500">12 teachers</td>
												</tr>
											</tbody>
										</table>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</HeroMotion>
		</section>

		<!-- Capabilities bento -->
		<MotionSection client:visible id="showcase" className="relative scroll-mt-24 border-t border-zinc-200/80 bg-white py-24 px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="reveal mb-14 max-w-3xl">
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-violet-600">01 — Capabilities</p>
					<h2 class="mt-3 font-display text-4xl tracking-tight text-zinc-900 sm:text-5xl text-balance">
						Built around how schools actually work
					</h2>
					<p class="mt-4 text-lg text-zinc-600">
						Real modules from the platform—grades, finance, gate kiosks, certificates, assessments, and more—connected in one place.
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-6 lg:grid-cols-12 lg:gap-5">
					<article class="bento-card group md:col-span-6 lg:col-span-7 lg:row-span-2 min-h-[280px] border-zinc-200/80 bg-gradient-to-br from-zinc-50 to-white p-8 shadow-sm">
						<div class="flex h-full flex-col justify-between">
							<div>
								<span class="inline-flex rounded-full bg-violet-100 px-3 py-1 text-xs font-semibold text-violet-800">Finance & cashiering</span>
								<h3 class="mt-4 font-display text-2xl text-zinc-900 sm:text-3xl">Fees, collections, receipts</h3>
								<p class="mt-3 max-w-lg text-zinc-600 leading-relaxed">
									Configure school fees, discounts, cashiering, and collections with receipt builder and ledger views—so the business office stays aligned with the classroom.
								</p>
							</div>
							<div class="mt-8 flex flex-wrap gap-2">
								<span class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-zinc-600">Cashiering</span>
								<span class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-zinc-600">Collections</span>
								<span class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-zinc-600">Receipt builder</span>
								<span class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-zinc-600">Student ledger</span>
							</div>
							<div class="mt-8 border-t border-zinc-200/80 pt-6">
								<p class="mb-3 text-[10px] font-semibold uppercase tracking-wider text-zinc-400">UI preview</p>
								<div class="mock-browser mock-browser-sm overflow-hidden shadow-md">
									<div class="mock-browser-chrome py-2">
										<span class="mock-dot bg-red-400"></span>
										<span class="mock-dot bg-amber-400"></span>
										<span class="mock-dot bg-emerald-400"></span>
										<span class="mock-url text-[9px]">…/finance/cashiering</span>
									</div>
									<div class="mock-browser-body py-3">
										<div class="flex gap-2 overflow-hidden rounded-md border border-zinc-200 bg-white">
											<div class="min-w-0 flex-1 divide-y divide-zinc-100 text-[9px]">
												<div class="flex justify-between gap-2 px-2 py-1 font-medium text-zinc-500">
													<span>OR</span><span class="tabular-nums text-zinc-800">2025-0142</span>
												</div>
												<div class="flex justify-between gap-2 px-2 py-1 text-zinc-700">
													<span class="truncate">Reyes, Ana</span><span class="shrink-0 font-semibold text-violet-700">₱4,250</span>
												</div>
											</div>
											<div class="w-20 shrink-0 bg-violet-50 px-2 py-2 text-center">
												<p class="text-[8px] font-medium uppercase text-violet-600">Shift</p>
												<p class="font-display text-sm text-zinc-900">₱48.9k</p>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</article>

					<article class="bento-card group md:col-span-6 lg:col-span-5 border-zinc-200/80 bg-white p-7 shadow-sm">
						<span class="inline-flex rounded-full bg-fuchsia-100 px-3 py-1 text-xs font-semibold text-fuchsia-900">Grades & records</span>
						<h3 class="mt-4 font-display text-xl text-zinc-900">Consolidated grades & SF9</h3>
						<p class="mt-2 text-sm leading-relaxed text-zinc-600">
							Section-level consolidation, proficiency views, and SF9 workflows for DepEd-aligned reporting.
						</p>
					</article>

					<article class="bento-card group !border-white/10 bg-zinc-950 p-7 text-white shadow-xl md:col-span-3 lg:col-span-5">
						<span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-violet-200">Gate & attendance</span>
						<h3 class="mt-4 font-display text-xl">Kiosk enter / exit</h3>
						<p class="mt-2 text-sm leading-relaxed text-zinc-400">
							Public gate flows plus teacher attendance grids and realtime indicators for daily operations.
						</p>
					</article>

					<article class="bento-card group md:col-span-3 lg:col-span-7 border-zinc-200/80 bg-gradient-to-br from-indigo-50/80 to-white p-7 shadow-sm">
						<span class="inline-flex rounded-full bg-indigo-100 px-3 py-1 text-xs font-semibold text-indigo-900">Teaching</span>
						<h3 class="mt-4 font-display text-xl text-zinc-900">Assigned subjects & lesson plans</h3>
						<p class="mt-2 text-sm leading-relaxed text-zinc-600">
							Class records, assessments, calendars, and AI-assisted planning—everything tied to sections and subjects.
						</p>
					</article>

					<article class="bento-card group md:col-span-3 lg:col-span-4 border-zinc-200/80 bg-white p-7 shadow-sm">
						<span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-900">Certificates</span>
						<h3 class="mt-4 font-display text-xl text-zinc-900">Visual certificate builder</h3>
						<p class="mt-2 text-sm text-zinc-600">Design, publish, and manage certificates without leaving the app.</p>
					</article>

					<article class="bento-card group md:col-span-3 lg:col-span-4 border-zinc-200/80 bg-white p-7 shadow-sm">
						<span class="inline-flex rounded-full bg-cyan-100 px-3 py-1 text-xs font-semibold text-cyan-900">Forms</span>
						<h3 class="mt-4 font-display text-xl text-zinc-900">Custom form builder</h3>
						<p class="mt-2 text-sm text-zinc-600">Drag-and-drop forms for enrollment, surveys, and internal workflows.</p>
					</article>

					<article class="bento-card group md:col-span-6 lg:col-span-4 border-zinc-200/80 bg-white p-7 shadow-sm">
						<span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-900">Students & assessments</span>
						<h3 class="mt-4 font-display text-xl text-zinc-900">Learner portal</h3>
						<p class="mt-2 text-sm text-zinc-600">
							Students take assessments, view subjects, manage personal info, and follow their own finance—role-aware and secure.
						</p>
					</article>
				</div>
			</div>
		</MotionSection>

		<ProductUiSection />

		<!-- Modules timeline -->
		<MotionSection client:visible id="solution" className="relative section-padding scroll-mt-24 border-t border-zinc-200/80 bg-stone-50 overflow-hidden">
			<div class="pointer-events-none absolute inset-0">
				<div class="absolute top-20 left-0 h-96 w-96 rounded-full bg-violet-200/20 blur-3xl"></div>
				<div class="absolute bottom-20 right-0 h-96 w-96 rounded-full bg-fuchsia-200/15 blur-3xl"></div>
			</div>

			<div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="mb-14 max-w-3xl reveal reveal-child">
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-violet-600">02 — Timeline</p>
					<h2 class="mt-3 font-display text-4xl tracking-tight text-zinc-900 sm:text-5xl text-balance">
						Your school year, mapped as modules
					</h2>
					<p class="mt-4 text-lg text-zinc-600">
						Follow how teams move through operations—from learners and staff to reporting and the classroom.
					</p>
				</div>

				<div class="relative mx-auto max-w-3xl">
					<div class="absolute left-[1.125rem] top-2 bottom-2 w-px bg-gradient-to-b from-violet-400 via-fuchsia-500 to-violet-600 md:left-1/2 md:-translate-x-1/2" aria-hidden="true"></div>

					<ol class="relative space-y-10 md:space-y-14">
						<!-- 01 -->
						<li class="relative grid grid-cols-1 gap-4 pl-10 md:grid-cols-2 md:gap-10 md:pl-0">
							<div class="absolute left-0 top-1 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-violet-500 to-violet-600 text-xs font-bold text-white shadow-lg shadow-violet-500/30 ring-4 ring-stone-50 md:left-1/2 md:-translate-x-1/2">01</div>
							<div class="md:col-start-1 md:row-start-1 md:pr-8 md:text-right">
								<p class="text-xs font-semibold uppercase tracking-wider text-violet-600">Foundation</p>
								<h3 class="mt-1 font-display text-xl text-zinc-900">Student management</h3>
							</div>
							<div class="md:col-start-2 md:row-start-1">
								<div class="rounded-2xl border border-zinc-200/80 bg-white p-5 shadow-sm transition hover:border-violet-300/60 hover:shadow-md">
									<div class="flex items-start gap-3">
										<div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-violet-500 to-violet-600 shadow-md">
											<svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
											</svg>
										</div>
										<p class="text-sm leading-relaxed text-zinc-600">Comprehensive student records, enrollment, and academic tracking in one profile.</p>
									</div>
								</div>
							</div>
